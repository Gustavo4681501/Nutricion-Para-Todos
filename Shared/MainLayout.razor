@inherits LayoutComponentBase
@inject NutricionApp.AppState AppState
@inject NavigationManager Nav
@implements IDisposable

<div class="page">
    @if (AppState.IsLoggedIn)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-success px-3">
            <a class="navbar-brand fw-bold" href="/dashboard">
                <i class="bi bi-heart-pulse-fill me-2"></i>Nutricion Para Todos
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">
                            <i class="bi bi-house me-1"></i>Inicio
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/alimentos">
                            <i class="bi bi-egg-fried me-1"></i>Alimentos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/menus">
                            <i class="bi bi-journal-text me-1"></i>Mis Menus
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/perfil">
                            <i class="bi bi-person me-1"></i>Perfil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/estadisticas">
                            <i class="bi bi-bar-chart me-1"></i>Estadisticas
                        </a>
                    </li>
                    @if (AppState.IsAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" href="/admin">
                                <i class="bi bi-shield-lock me-1"></i>Admin
                            </a>
                        </li>
                    }
                </ul>
                <span class="navbar-text text-white me-3">
                    <i class="bi bi-person-circle me-1"></i>@AppState.CurrentUser.UserName
                    @if (AppState.IsAdmin)
                    {
                        <span class="badge bg-warning text-dark ms-1">Admin</span>
                    }
                </span>
                <button class="btn btn-outline-light btn-sm" @onclick="Logout">
                    <i class="bi bi-box-arrow-right me-1"></i>Salir
                </button>
            </div>
        </nav>
    }
    <main class="container py-4">@Body</main>
    <footer class="text-center text-muted py-3 border-top mt-auto">
        <small>Nutricion Para Todos &copy; 2025 — Proyecto #2</small>
    </footer>
</div>

@code {
    protected override void OnInitialized() => AppState.OnChange += StateHasChanged;
    void Logout() { AppState.Logout(); Nav.NavigateTo("/login", forceLoad: true); }
    public void Dispose() => AppState.OnChange -= StateHasChanged;
}
