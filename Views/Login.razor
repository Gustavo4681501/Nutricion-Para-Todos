@page "/login"
@page "/"
@using NutricionApp.Models
@inject NutricionApp.Controllers.LoginController LoginCtrl
@inject NutricionApp.AppState AppState
@inject NavigationManager Nav

<PageTitle>Login — Nutricion Para Todos</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header bg-success text-white text-center py-3">
                <h4 class="mb-0"><i class="bi bi-heart-pulse-fill me-2"></i>Nutricion Para Todos</h4>
            </div>
            <div class="card-body p-4">
                <h5 class="card-title text-center mb-4">Iniciar Sesion</h5>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }
                <div class="mb-3">
                    <label class="form-label">Usuario</label>
                    <input class="form-control" @bind="_userName" placeholder="Nombre de usuario" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Contrasena</label>
                    <input class="form-control" type="password" @bind="_password"
                           @onkeydown="@(e => { if (e.Key == "Enter") DoLogin(); })" />
                </div>
                <button class="btn btn-success w-100 mb-2" @onclick="DoLogin">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Ingresar
                </button>
                <a href="/registro" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-person-plus me-1"></i>Crear cuenta
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    string _userName = string.Empty;
    string _password = string.Empty;
    string _error    = string.Empty;

    protected override void OnInitialized()
    {
        if (AppState.IsLoggedIn) Nav.NavigateTo("/dashboard");
    }

    void DoLogin()
    {
        _error = string.Empty;
        if (string.IsNullOrWhiteSpace(_userName) || string.IsNullOrWhiteSpace(_password))
        { _error = "Ingrese usuario y contrasena."; return; }

        if (!LoginCtrl.Login(_userName.Trim(), _password))
        { _error = "Credenciales incorrectas o cuenta inactiva."; return; }

        AppState.SetUser(LoginCtrl.GetUser(_userName.Trim()));
        Nav.NavigateTo("/dashboard");
    }
}
