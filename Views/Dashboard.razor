@page "/dashboard"
@using NutricionApp.Models
@inject NutricionApp.AppState AppState
@inject NutricionApp.Controllers.PerfilController PerfilCtrl
@inject NutricionApp.Controllers.MenuController MenuCtrl
@inject NavigationManager Nav

<PageTitle>Inicio</PageTitle>
@if (!AppState.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<h2 class="mb-4">Bienvenido, <strong>@AppState.CurrentUser.UserName</strong> 👋</h2>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100 border-success">
            <div class="card-header bg-success text-white"><i class="bi bi-person-fill me-2"></i>Mi Perfil</div>
            <div class="card-body">
                @if (_tienePerfil)
                {
                    <table class="table table-sm mb-0">
                        <tr><td>Edad</td><td><strong>@_edad anos</strong></td></tr>
                        <tr><td>Peso / Altura</td><td><strong>@_pesoKg kg / @_alturaCm cm</strong></td></tr>
                        <tr><td>IMC</td><td><strong>@_imc.ToString("F1")</strong></td></tr>
                        <tr><td>Objetivo</td><td><strong>@_objetivo</strong></td></tr>
                        <tr><td>Dieta</td><td><strong>@_dieta</strong></td></tr>
                        <tr><td>Meta calórica</td><td><strong class="text-success">@_caloriasRec.ToString("F0") kcal</strong></td></tr>
                    </table>
                }
                else
                {
                    <p class="text-muted">No has completado tu perfil.</p>
                    <a href="/perfil" class="btn btn-sm btn-success">Completar perfil</a>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 border-info">
            <div class="card-header bg-info text-white"><i class="bi bi-journal-text me-2"></i>Ultimo Menu</div>
            <div class="card-body">
                @if (_lastMenu != null)
                {
                    <p class="mb-2"><small class="text-muted">@_lastMenu.Fecha.ToString("dd/MM/yyyy")</small></p>
                    <div class="row text-center mb-2">
                        <div class="col-3"><div class="fw-bold text-danger">@_lastMenu.TotalCalorias().ToString("F0")</div><small>kcal</small></div>
                        <div class="col-3"><div class="fw-bold text-primary">@_lastMenu.TotalProteinas().ToString("F1")g</div><small>Prot</small></div>
                        <div class="col-3"><div class="fw-bold text-warning">@_lastMenu.TotalCarbohidratos().ToString("F1")g</div><small>Carbs</small></div>
                        <div class="col-3"><div class="fw-bold text-secondary">@_lastMenu.TotalGrasas().ToString("F1")g</div><small>Grasas</small></div>
                    </div>
                    @foreach (var it in _lastMenu.Items)
                    {
                        <small class="d-block">• @it.NombreAlimento (@it.CantidadGramos g) — @it.Calorias.ToString("F0") kcal</small>
                    }
                }
                else
                {
                    <p class="text-muted">Sin menus registrados.</p>
                    <a href="/menus" class="btn btn-sm btn-info text-white">Crear menu</a>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-6 col-md-3"><a href="/menus"        class="btn btn-outline-success w-100 py-3"><i class="bi bi-plus-circle d-block fs-4"></i>Nuevo Menu</a></div>
    <div class="col-6 col-md-3"><a href="/alimentos"    class="btn btn-outline-primary w-100 py-3"><i class="bi bi-egg-fried d-block fs-4"></i>Alimentos</a></div>
    <div class="col-6 col-md-3"><a href="/perfil"       class="btn btn-outline-warning w-100 py-3"><i class="bi bi-person-gear d-block fs-4"></i>Mi Perfil</a></div>
    <div class="col-6 col-md-3"><a href="/estadisticas" class="btn btn-outline-info w-100 py-3"><i class="bi bi-bar-chart d-block fs-4"></i>Estadisticas</a></div>
</div>

@code {
    // Primitives to avoid NutricionApp.Views.Perfil namespace collision
    bool   _tienePerfil = false;
    int    _edad        = 0;
    double _pesoKg      = 0;
    double _alturaCm    = 0;
    string _objetivo    = string.Empty;
    string _dieta       = string.Empty;
    double _imc         = 0;
    double _caloriasRec = 0;

    NutricionApp.Models.Menu _lastMenu = null;

    protected override void OnInitialized()
    {
        if (!AppState.IsLoggedIn) return;

        var p = PerfilCtrl.ObtenerPerfil(AppState.CurrentUser.UserName);
        if (p != null && p.PesoKg > 0)
        {
            _tienePerfil = true;
            _edad        = p.Edad;
            _pesoKg      = p.PesoKg;
            _alturaCm    = p.AlturaCm;
            _objetivo    = p.Objetivo.ToString();
            _dieta       = p.Dieta.ToString();
            _imc         = p.IMC();
            _caloriasRec = p.CaloriasRecomendadas();
        }

        var menus = MenuCtrl.ObtenerPorUsuario(AppState.CurrentUser.UserName);
        _lastMenu = menus.Count > 0 ? menus[0] : null;
    }
}
