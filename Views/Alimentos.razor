@page "/alimentos"
@using NutricionApp.Models
@using System.Linq
@inject NutricionApp.Controllers.AlimentoController AlimentoCtrl
@inject NutricionApp.AppState AppState
@inject NavigationManager Nav

<PageTitle>Alimentos</PageTitle>
@if (!AppState.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<h2 class="mb-3"><i class="bi bi-egg-fried me-2"></i>Catalogo de Alimentos</h2>

<div class="row mb-3">
    <div class="col-md-6">
        <input class="form-control" placeholder="Buscar alimento..." @bind="_search" @bind:event="oninput" />
    </div>
    <div class="col-md-3">
        <button class="btn btn-success" @onclick="NuevoAlimento">
            <i class="bi bi-plus-circle me-1"></i>Agregar
        </button>
    </div>
</div>

@if (_editando != null)
{
    <div class="card mb-4 border-success shadow-sm">
        <div class="card-header bg-success text-white">
            @(_esNuevo ? "Nuevo Alimento" : "Editar Alimento")
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" @bind="_editando.Nombre" disabled="@(!_esNuevo)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Calorias (kcal)</label>
                    <input class="form-control" type="number" step="0.1" @bind="_editando.Calorias" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Proteinas (g)</label>
                    <input class="form-control" type="number" step="0.1" @bind="_editando.Proteinas" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Carbohidratos (g)</label>
                    <input class="form-control" type="number" step="0.1" @bind="_editando.Carbohidratos" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Grasas (g)</label>
                    <input class="form-control" type="number" step="0.1" @bind="_editando.Grasas" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Porcion (g)</label>
                    <input class="form-control" type="number" @bind="_editando.Porcion" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-success me-2" @onclick="GuardarEdicion">
                    <i class="bi bi-floppy me-1"></i>Guardar
                </button>
                <button class="btn btn-secondary" @onclick="CancelarEdicion">Cancelar</button>
            </div>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover table-striped align-middle">
        <thead class="table-success">
            <tr>
                <th>Nombre</th><th>Calorias</th><th>Proteinas</th>
                <th>Carbohidratos</th><th>Grasas</th><th>Porcion</th><th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Filtrados())
            {
                <tr>
                    <td>@a.Nombre</td>
                    <td>@a.Calorias kcal</td>
                    <td>@a.Proteinas g</td>
                    <td>@a.Carbohidratos g</td>
                    <td>@a.Grasas g</td>
                    <td>@a.Porcion g</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditarAlimento(a)">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarAlimento(a)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    List<Alimento> _alimentos = new List<Alimento>();
    Alimento       _editando  = null;
    bool           _esNuevo   = false;
    string         _search    = string.Empty;

    protected override void OnInitialized() => Cargar();

    void Cargar() => _alimentos = AlimentoCtrl.ObtenerTodos();

    IEnumerable<Alimento> Filtrados() =>
        string.IsNullOrWhiteSpace(_search)
            ? _alimentos
            : _alimentos.Where(a => a.Nombre.Contains(_search, StringComparison.OrdinalIgnoreCase));

    void NuevoAlimento()
    {
        _esNuevo  = true;
        _editando = new Alimento(string.Empty, 0, 0, 0, 0, 100);
    }

    void EditarAlimento(Alimento a)
    {
        _esNuevo  = false;
        _editando = new Alimento(a.Nombre, a.Calorias, a.Proteinas, a.Carbohidratos, a.Grasas, a.Porcion);
    }

    void GuardarEdicion()
    {
        if (string.IsNullOrWhiteSpace(_editando.Nombre)) return;
        if (_esNuevo) AlimentoCtrl.Agregar(_editando);
        else          AlimentoCtrl.Actualizar(_editando);
        _editando = null;
        Cargar();
    }

    void CancelarEdicion() => _editando = null;

    void EliminarAlimento(Alimento a)
    {
        AlimentoCtrl.EliminarPorNombre(a.Nombre);
        Cargar();
    }
}
