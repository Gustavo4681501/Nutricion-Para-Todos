<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(NutricionApp.Shared.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(NutricionApp.Shared.MainLayout)">
            <p>Pagina no encontrada.</p>
            <a href="/">Volver al inicio</a>
        </LayoutView>
    </NotFound>
</Router>
